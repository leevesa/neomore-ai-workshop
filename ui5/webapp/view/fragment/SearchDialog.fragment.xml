<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="searchDialogTitle"
        contentHeight="500px"
        contentWidth="500px"
        stretch="{Device>/isPhone}">
        <subHeader>
            <Toolbar>
                <SearchField
                    id="searchDialogSearchField"
                    width="100%"
                />
            </Toolbar>
        </subHeader>
        <content>
            <Bar
                id="selectAllCheckBoxBar">
                <contentLeft>
                    <CheckBox
                        id="selectAllCheckBox"
                        text="{i18n>SELECT_ALL_LABEL}"
                        select="onSelectAllPress"/>
                </contentLeft>
            </Bar>
            <Table
                id="searchDialogList"
                fixedLayout="false"
                selectionChange="onSearchDialogSelectionChange"
                items="{Viewmodel>/PlaceHolder}"
                growing="true"
                growingThreshold="100"
                growingTriggerText="{i18n>SEARCH_GROWING_TEXT}">
                <columns>
                    <Column />
                    <Column />
                </columns>
                <items>
                    <ColumnListItem
                        id="searchDialogListItem"
                        selected="{Viewmodel>PlaceHolder}"
                        type="Active"
                        press="onSearchDialogItemPress">
                        <cells>
                            <Text
                                id="searchDialogListValue"
                                text="{Viewmodel>PlaceHolder}"
                            />
                            <Text
                                id="searchDialogListDescription"
                                text="{Viewmodel>PlaceHolder}"
                            />
                        </cells>
                        </ColumnListItem>
                </items>
                </Table>
        </content>
        <buttons>
            <Button
                id="selectSelectionButton"
                visible="false"
                text="{i18n>SELECT_BUTTON_TEXT}"
                type="Emphasized"
            />
            <Button
                id="searchDialogCloseButton"
                text="{i18n>CLOSE_BUTTON_TEXT}"
                type="Transparent"
            />
        </buttons>
    </Dialog>
</core:FragmentDefinition>
