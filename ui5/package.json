{
  "name": "fi.neomore.template",
  "version": "1.0.0",
  "private": true,
  "description": "Template Fiori application",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@babel/eslint-parser": "7.14.7",
    "@sap-ux/eslint-plugin-fiori-tools": "^0.5.0",
    "@sap/ui5-builder-webide-extension": "^1.1.9",
    "@sap/ux-ui5-tooling": "^1.14.3",
    "@ui5/cli": "^4.0.6",
    "@wdio/cli": "^8.40.5",
    "@wdio/local-runner": "^8.40.5",
    "@wdio/mocha-framework": "^8.40.3",
    "@wdio/spec-reporter": "^8.40.3",
    "axios": "^1.7.7",
    "clean-jsdoc-theme": "^4.3.0",
    "commander": "^12.1.0",
    "eslint": "^9.9.1",
    "eslint-plugin-fiori-custom": "2.6.7",
    "form-data": "^4.0.0",
    "js-yaml": "^4.1.0",
    "jsdoc": "^4.0.3",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-qunit": "^4.2.1",
    "karma-ui5": "^4.0.1",
    "karma-verbose-reporter": "^0.0.8",
    "less": "^4.2.0",
    "mbt": "^1.2.31",
    "qunit": "^2.22.0",
    "replace": "^1.2.1",
    "ui5-task-zipper": "^3.2.2",
    "wdio-chromedriver-service": "^8.1.1",
    "wdio-ui5-service": "^2.0.10",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "fiori run --open \"test/flpSandbox.html?sap-ui-xx-viewCache=false#fineomoretemplate-display\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"test/flpSandbox.html?sap-ui-xx-viewCache=false#fineomoretemplate-display\"",
    "start-localhost": "fiori run --config ./ui5-localhost.yaml --open \"test/flpSandbox.html?sap-ui-xx-viewCache=false#fineomoretemplate-display\"",
    "start-mockserver": "fiori run --config ./ui5-mockserver.yaml --open \"test/flpSandboxMockserver.html?sap-ui-xx-viewCache=false#fineomoretemplate-display\"",
    "start-noflp": "fiori run --open \"index.html?sap-ui-xx-viewCache=false\"",
    "start-variants-management": "fiori run --open \"preview.html?sap-ui-xx-viewCache=false&fiori-tools-rta-mode=true&sap-ui-rta-skip-flex-validation=true#preview-app\"",
    "lint": "eslint ./",
    "less": "lessc ./webapp/css/styles.less ./webapp/css/styles.css",
    "jsdoc": "jsdoc --configure jsdoc.json --verbose",
    "deploy": "npm run build && fiori deploy --config ui5-deploy.yaml",
    "deploy-config": "fiori add deploy-config",
    "build": "npm run less && ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "build:cf": "npm run less && ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo",
    "build:mta": "npm run less && rimraf resources mta_archives && mbt build --mtar archive",
    "deploy:mta": "cf deploy mta_archives/archive.mtar",
    "build-and-deploy": "npm run build:mta && npm run deploy:mta",
    "undeploy": "npm run build && fiori undeploy --config ui5-deploy.yaml",
    "version-update": "node ./hooks/version-update",
    "test": "karma start --singleRun",
    "test:watch": "karma start",
    "test:coverage": "karma start --coverage",
    "wdi5": "wdio run ./wdio.conf.js",
    "deploy-test": "npm run build && fiori deploy --config ui5-deploy.yaml --testMode true"
  },
  "ui5": {
    "ui5linter": {
      "severity": {
        "UnusedClassLinter": "Warning"
      },
      "usage": {
        "PublicMemberLinter": false,
        "WrongFilePathLinter": false,
        "TagAttributeLinter": false
      }
    }
  },
  "sapuxLayer": "CUSTOMER_BASE"
}
